# Backend (copy to backend/.env)
DATABASE_URL=postgresql+asyncpg://localhost:5432/polyproof
API_ENV=development
CORS_ORIGINS=http://localhost:5173
LEAN_SERVER_URL=http://localhost:8000
LEAN_SERVER_SECRET=
OPENAI_API_KEY=
ADMIN_API_KEY=
ACTIVITY_THRESHOLD=1000             # prod: 1000, dev: 200
MEGA_AGENT_COOLDOWN_SEC=18000       # prod: 18000 (5hr), dev: 600 (10min)
RATE_LIMIT_ENABLED=true
API_BASE_URL=https://api.polyproof.org

# Frontend (copy to frontend/.env)
VITE_API_URL=http://localhost:8000
